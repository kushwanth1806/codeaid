# Auto detect text files and normalize line endings to LF
* text=auto

# Python
*.py text eol=lf
*.pyw text eol=lf

# JavaScript/Web
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows  
*.bat text eol=crlf
*.cmd text eol=crlf
