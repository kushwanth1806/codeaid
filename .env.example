# CodeAID Configuration
# Copy this file to .env and fill in your values

# LLM Configuration (Optional)
# Leave empty if you don't want AI-powered insights
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_PROVIDER=anthropic  # Options: anthropic, openai

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=false
DEBUG=false

# Server Configuration
HOST=0.0.0.0
PORT=5001
MAX_CONTENT_LENGTH=52428800  # 50MB in bytes

# File Upload Configuration
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=zip,py,js,ts,jsx,tsx,java,go,rs,rb,php,cs

# Repository Configuration
REPO_TIMEOUT_SECONDS=300
REPO_MAX_SIZE_MB=500

# Analysis Configuration
PYTHON_MIN_VERSION=3.9
MAX_ISSUES_TO_DISPLAY=100

# Output Configuration
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
